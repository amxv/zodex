---
import BaseLayout from "zuedocs/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { primaryNav, siteConfig } from "../data/docs";

const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);

const proofPoints = [
  {
    title: "Built for ChatGPT",
    body: "zodex is designed around ChatGPT MCP sessions. The tool shape is intentionally familiar to GPT models: run commands, keep sessions alive, and apply patches."
  },
  {
    title: "Real Sprite workspaces",
    body: "Give ChatGPT an actual Linux machine for clone-edit-test-commit loops without keeping a full VPS warm when no agent is working."
  },
  {
    title: "Write autonomy by policy",
    body: "Choose PR-only, push-on-request, operator-granted push, timed YOLO, repo-scoped YOLO, or no-TTL YOLO for trusted sessions."
  },
  {
    title: "Normal Git when trusted",
    body: "Agents can publish PRs without direct shell write tokens, or use plain git push when the operator opens the right write window."
  }
];

const autonomyModes = [
  "Start safe with read-only clone/fetch, local commits, and PR publishing through the publisher daemon.",
  "Approve a one-off push from ChatGPT with a repo-scoped request-push grant and the default 30 minute TTL.",
  "Grant write access remotely from the operator machine when the browser/device-flow approval should stay with the human.",
  "Enable YOLO mode for a trusted session, scoped to selected repos or all installed repos, with a TTL or intentionally no TTL."
];
---

<BaseLayout
  title={`${siteConfig.name} | ${siteConfig.strapline}`}
  description={siteConfig.description}
  siteConfig={siteConfig}
  primaryNav={primaryNav}
>
  <section class="hero shell">
    <div class="hero__copy">
      <p class="section-label">ChatGPT-native remote coding workspace</p>
      <h1>
        Give ChatGPT a real Linux coding machine, then choose exactly how much it can push.
      </h1>
      <p class="hero__lede">
        zodex runs a Sprite-backed MCP runtime built for ChatGPT coding sessions. GPT models get
        a familiar command, stdin, and patch surface, while operators keep control over GitHub
        writes: PR-only, push-on-approval, or scoped YOLO for trusted work.
      </p>
      <p class="hero__annotation">
        The default path is safe. ChatGPT can clone, edit, test, and commit on the Sprite before
        any GitHub write window exists. When speed matters, the operator can open direct push for
        one repo, several repos, or all installed repos for a bounded duration or indefinitely.
      </p>
      <div class="hero__actions">
        <a class="button button--solid" href="/docs/quickstart">Connect ChatGPT</a>
        <a class="button button--ghost" href="/docs/write-modes">Compare write modes</a>
      </div>
    </div>
    <aside class="hero__panel">
      <p class="hero__panel-label">Operator control</p>
      <ul class="hero__signal-list">
        <li>Expose `/mcp?key=...` to ChatGPT.</li>
        <li>Run GPT-friendly command/stdin/patch tools.</li>
        <li>Pick PR-only, approved push, or YOLO mode.</li>
      </ul>
      <div class="hero__terminal">
        <span>$ zodex sprite setup --sprite dev --repo amxv/zodex</span>
        <span>$ zodex-agent github publish-pr --repo amxv/zodex</span>
        <span>$ zodex-agent github request-push --repo amxv/zodex</span>
        <span>$ zodex github mode yolo --sprite dev --repo amxv/zodex --ttl 4h</span>
      </div>
    </aside>
  </section>

  <section class="shell section-grid">
    <div class="section-heading">
      <p class="section-label">Why it exists</p>
      <h2>ChatGPT is better at coding when it gets the kind of tools it already knows.</h2>
      <p>
        zodex gives ChatGPT the same basic primitives GPT coding workflows rely on: run a shell
        command, continue an interactive process, and apply a targeted patch. The difference is that
        those tools operate on a real Sprite workspace with real Git history, real tests, and real
        service processes.
      </p>
    </div>
    <div class="proof-grid">
      {proofPoints.map((item) => (
        <article class="proof-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell split-section">
    <div>
      <p class="section-label">Autonomy ladder</p>
      <h2>Start with review. Open direct push only when the session deserves it.</h2>
    </div>
    <div class="stack-list">
      {autonomyModes.map((item) => (
        <article class="stack-list__item">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell capability-band">
    <div class="capability-band__intro">
      <p class="section-label">Runtime pieces</p>
      <h2>ChatGPT front door, Sprite workspace, MCP daemon, GitHub apps, and operator CLI.</h2>
    </div>
    <div class="capability-band__grid">
      <div>
        <p class="capability-title">ChatGPT MCP</p>
        <p>Connect ChatGPT to a stable `/mcp?key=...` URL and give it the three-tool coding surface it handles well.</p>
      </div>
      <div>
        <p class="capability-title">Sprites.dev</p>
        <p>Spin up a remote Linux environment for agent work instead of paying for always-idle VPS capacity.</p>
      </div>
      <div>
        <p class="capability-title">zodexd</p>
        <p>Sprite-side MCP daemon for command execution, interactive stdin writes, patch application, health, and HTTP routes.</p>
      </div>
      <div>
        <p class="capability-title">zodex-agent</p>
        <p>Guest-side helper for PR publishing, request-push grants, grant listing, revocation, and MCP URL hints.</p>
      </div>
      <div>
        <p class="capability-title">zodex</p>
        <p>Operator CLI for Sprite setup, upgrades, logs, proxy checks, remote grants, and scoped YOLO mode.</p>
      </div>
      <div>
        <p class="capability-title">GitHub Apps</p>
        <p>Reader and writer apps separate always-on read access from PR publishing and direct-push policy.</p>
      </div>
    </div>
  </section>

  <section class="shell docs-teaser">
    <div class="section-heading">
      <p class="section-label">Docs map</p>
      <h2>Connect ChatGPT first, then choose the right write mode for each repo.</h2>
      <p>
        The docs follow the real operating path: install zodex, connect ChatGPT to the Sprite MCP
        front door, understand the write modes, configure GitHub Apps, operate the Sprite services,
        and troubleshoot grants, YOLO mode, proxy routing, and command execution.
      </p>
    </div>
    <div class="docs-teaser__grid">
      {docs.map((entry) => (
        <a class="docs-teaser__card" href={`/docs/${entry.id}`}>
          <span>{entry.data.category}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.summary ?? entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="shell closing-note">
    <p>
      zodex is for ChatGPT coding sessions that need a real machine, normal Git, and an operator-controlled
      path from careful PR review to trusted YOLO pushes.
    </p>
  </section>
</BaseLayout>
